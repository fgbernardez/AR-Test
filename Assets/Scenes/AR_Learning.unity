      m_Calls: []
  m_text: "A sphere is a three-dimensional round-shaped object. Unlike other three-dimensional
    shapes, a sphere does not have any vertices or edges. Also, the distance from
    the center of the sphere to any point on the surface is equal. \n\n<b>Formula:
    V = (4/3)\u03C0r<sup>3</sup></b>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2e498d1c8094910479dc3e1b768306a4, type: 2}
