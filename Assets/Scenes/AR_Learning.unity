  m_text: 'A cube is a three-dimensional solid object in geometry. A cube has eight
    vertices and twelve straight edges of the same length, so that these edges form
    six square faces of the same size.


    <b>Formula: <i>V = s<sup>3</sup></i></b>'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2e498d1c8094910479dc3e1b768306a4, type: 2}
